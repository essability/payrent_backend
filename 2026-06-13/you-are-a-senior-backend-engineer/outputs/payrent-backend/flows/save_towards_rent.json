{
  "version": "7.1",
  "data_api_version": "3.0",
  "routing_model": {
    "SAVE_TOWARDS_RENT": []
  },
  "screens": [
    {
      "id": "SAVE_TOWARDS_RENT",
      "title": "Save Towards Rent",
      "terminal": true,
      "success": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "save_towards_rent_form",
            "children": [
              {
                "type": "TextInput",
                "name": "full_name",
                "label": "Full Name",
                "required": true,
                "input-type": "text"
              },
              {
                "type": "TextInput",
                "name": "phone_number",
                "label": "Phone Number",
                "required": true,
                "input-type": "phone"
              },
              {
                "type": "TextInput",
                "name": "monthly_rent_amount",
                "label": "Monthly Rent Amount",
                "required": true,
                "input-type": "number"
              },
              {
                "type": "TextInput",
                "name": "rent_due_day",
                "label": "Rent Due Day",
                "required": true,
                "input-type": "number"
              },
              {
                "type": "Dropdown",
                "name": "savings_frequency",
                "label": "Savings Frequency",
                "required": true,
                "data-source": [
                  { "id": "daily", "title": "Daily" },
                  { "id": "weekly", "title": "Weekly" },
                  { "id": "monthly", "title": "Monthly" }
                ]
              },
              {
                "type": "TextInput",
                "name": "target_start_date",
                "label": "Target Start Date",
                "required": false,
                "input-type": "text"
              },
              {
                "type": "Footer",
                "label": "Create savings goal",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "flow_name": "save_towards_rent",
                    "full_name": "${form.full_name}",
                    "phone_number": "${form.phone_number}",
                    "monthly_rent_amount": "${form.monthly_rent_amount}",
                    "rent_due_day": "${form.rent_due_day}",
                    "savings_frequency": "${form.savings_frequency}",
                    "target_start_date": "${form.target_start_date}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
