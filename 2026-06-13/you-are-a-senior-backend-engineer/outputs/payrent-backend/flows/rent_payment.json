{
  "version": "7.1",
  "data_api_version": "3.0",
  "routing_model": {
    "RENT_PAYMENT": []
  },
  "screens": [
    {
      "id": "RENT_PAYMENT",
      "title": "Record Rent Payment",
      "terminal": true,
      "success": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "rent_payment_form",
            "children": [
              {
                "type": "TextInput",
                "name": "tenant_phone_number",
                "label": "Tenant phone number",
                "required": true,
                "input-type": "phone"
              },
              {
                "type": "TextInput",
                "name": "amount",
                "label": "Amount paid",
                "required": true,
                "input-type": "number"
              },
              {
                "type": "Dropdown",
                "name": "method",
                "label": "Payment method",
                "required": true,
                "data-source": [
                  { "id": "mpesa", "title": "M-Pesa" },
                  { "id": "bank_transfer", "title": "Bank Transfer" },
                  { "id": "cash", "title": "Cash" },
                  { "id": "card", "title": "Card" },
                  { "id": "other", "title": "Other" }
                ]
              },
              {
                "type": "TextInput",
                "name": "provider_reference",
                "label": "Payment reference",
                "required": false,
                "input-type": "text"
              },
              {
                "type": "TextInput",
                "name": "invoice_number",
                "label": "Invoice number",
                "required": false,
                "input-type": "text"
              },
              {
                "type": "TextInput",
                "name": "transaction_pin",
                "label": "Transaction PIN",
                "required": true,
                "input-type": "number"
              },
              {
                "type": "Footer",
                "label": "Record payment",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "flow_name": "rent_payment",
                    "tenant_phone_number": "${form.tenant_phone_number}",
                    "amount": "${form.amount}",
                    "method": "${form.method}",
                    "provider_reference": "${form.provider_reference}",
                    "invoice_number": "${form.invoice_number}",
                    "transaction_pin": "${form.transaction_pin}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
