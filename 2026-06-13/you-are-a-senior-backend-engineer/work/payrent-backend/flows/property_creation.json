{
  "version": "7.1",
  "data_api_version": "3.0",
  "routing_model": {
    "PROPERTY_CREATION": []
  },
  "screens": [
    {
      "id": "PROPERTY_CREATION",
      "title": "Create Property",
      "terminal": true,
      "success": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "property_creation_form",
            "children": [
              {
                "type": "TextInput",
                "name": "owner_phone_number",
                "label": "Owner phone number",
                "required": true,
                "input-type": "phone"
              },
              {
                "type": "TextInput",
                "name": "property_name",
                "label": "Property name",
                "required": true,
                "input-type": "text"
              },
              {
                "type": "TextInput",
                "name": "address",
                "label": "Address",
                "required": false,
                "input-type": "text"
              },
              {
                "type": "TextInput",
                "name": "city",
                "label": "City",
                "required": true,
                "input-type": "text"
              },
              {
                "type": "TextInput",
                "name": "county",
                "label": "County",
                "required": true,
                "input-type": "text"
              },
              {
                "type": "TextInput",
                "name": "unit_number",
                "label": "First unit number",
                "required": true,
                "input-type": "text"
              },
              {
                "type": "TextInput",
                "name": "monthly_rent_amount",
                "label": "Monthly rent amount",
                "required": true,
                "input-type": "number"
              },
              {
                "type": "TextInput",
                "name": "rent_due_day",
                "label": "Rent due day",
                "required": true,
                "input-type": "number"
              },
              {
                "type": "Footer",
                "label": "Create property",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "flow_name": "property_creation",
                    "owner_phone_number": "${form.owner_phone_number}",
                    "property_name": "${form.property_name}",
                    "address": "${form.address}",
                    "city": "${form.city}",
                    "county": "${form.county}",
                    "unit_number": "${form.unit_number}",
                    "monthly_rent_amount": "${form.monthly_rent_amount}",
                    "rent_due_day": "${form.rent_due_day}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
