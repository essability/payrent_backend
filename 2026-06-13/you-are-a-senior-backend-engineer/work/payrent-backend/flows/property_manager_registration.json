{
  "version": "7.1",
  "data_api_version": "3.0",
  "routing_model": {
    "PROPERTY_MANAGER_REGISTRATION": []
  },
  "screens": [
    {
      "id": "PROPERTY_MANAGER_REGISTRATION",
      "title": "Manager Registration",
      "terminal": true,
      "success": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "property_manager_registration_form",
            "children": [
              {
                "type": "TextInput",
                "name": "full_name",
                "label": "Full name",
                "required": true,
                "input-type": "text"
              },
              {
                "type": "TextInput",
                "name": "company_name",
                "label": "Company name",
                "required": true,
                "input-type": "text"
              },
              {
                "type": "TextInput",
                "name": "phone_number",
                "label": "Phone number",
                "required": true,
                "input-type": "phone"
              },
              {
                "type": "TextInput",
                "name": "email",
                "label": "Email",
                "required": true,
                "input-type": "email"
              },
              {
                "type": "TextInput",
                "name": "national_id_number",
                "label": "Kenyan ID number",
                "required": true,
                "input-type": "number"
              },
              {
                "type": "Footer",
                "label": "Create manager account",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "flow_name": "property_manager_registration",
                    "full_name": "${form.full_name}",
                    "company_name": "${form.company_name}",
                    "phone_number": "${form.phone_number}",
                    "email": "${form.email}",
                    "national_id_number": "${form.national_id_number}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
