{
  "version": "7.1",
  "data_api_version": "3.0",
  "routing_model": { "RENT_BALANCE_CHECK": [] },
  "screens": [
    {
      "id": "RENT_BALANCE_CHECK",
      "title": "Check Rent Balance",
      "terminal": true,
      "success": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "rent_balance_check_form",
            "children": [
              { "type": "TextInput", "name": "tenant_phone_number", "label": "Phone number", "required": true, "input-type": "phone" },
              {
                "type": "Footer",
                "label": "Check balance",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "flow_name": "rent_balance_check",
                    "tenant_phone_number": "${form.tenant_phone_number}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
